      "id": "decompose-004",
      "category": "任务拆解",
      "description": "批量上限：超过5个子任务 → 分批创建",
      "input": {
        "task": "重构整个计算器App",
        "type": "type:feature",
        "size": "L",
        "estimated_subtasks": 8
      },
      "expected": {
        "batch_limit": 5,
        "note": "超过批量上限，需分2批创建（5 + 3）"
      }
    },
    {
      "id": "decompose-005",
      "category": "任务拆解",
      "description": "深度限制：最多2层（L→M→S）",
      "input": {
        "task": "大任务A（L级）",
        "type": "type:feature",
        "size": "L",
        "subtask": "子任务B（M级）"
      },
      "expected": {
        "max_depth": 2,
        "note": "子任务B已是M级，不继续拆解。禁止递归拆解S级任务"
      }
    },
    {
      "id": "decompose-006",
      "category": "任务拆解",
      "description": "依赖标记：子任务3依赖子任务1+2",
      "input": {
        "subtasks": [
          {"id": 1, "title": "数据层实现", "independent": true},
          {"id": 2, "title": "UI层实现", "independent": true},
          {"id": 3, "title": "集成验证", "depends_on": [1, 2]}
        ]
      },
      "expected": {
        "dependency_marking": [
          "#N3 depends on #N1（需N1完成后再开工）",
          "#N3 depends on #N2（需N2完成后再开工）"
        ],
        "note": "父Issue需标记依赖关系，避免assignee同时开工"
      }
    },
