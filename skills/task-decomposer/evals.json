        {"type": "type:learning", "expected_assignee": "IntelliJungle"},
        {"type": "type:docs", "expected_assignee": "IntelliJungle"},
        {"type": "type:decision", "expected_assignee": "zhangtbj"}
      ],
      "expected": {
        "all_match": true,
        "note": "七种类型各映射到正确的角色"
      }
